# Multi-stage build for Web UI
FROM node:18-alpine AS web-build

WORKDIR /app

# Copy package files
COPY web/package*.json ./
RUN npm ci --only=production

# Copy web source files
COPY web/ ./

# Build the production web assets with MSAL integration
RUN npm run build

# Production web server
FROM nginx:alpine

# Copy built web assets
COPY --from=web-build /app/dist /usr/share/nginx/html

# Copy nginx configuration
COPY web/nginx.conf /etc/nginx/conf.d/default.conf

# Add environment variable injection script
COPY web/inject-env.sh /docker-entrypoint.d/inject-env.sh
RUN chmod +x /docker-entrypoint.d/inject-env.sh

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]